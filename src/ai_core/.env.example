# Confidence threshold for person detection (0.0-1.0)
# Higher = more confident detections, lower = more sensitive
PERSON_CONFIDENCE_THRESHOLD=0.4

# Enable/disable mask detection feature
# Options: true, false
MASK_DETECTION_ENABLED=true

# Confidence threshold for mask detection (0.0-1.0)
# Higher = more confident detections, lower = more sensitive
MASK_CONFIDENCE_THRESHOLD=0.5

# Enable/disable age and gender detection
# Uses InsightFace genderage module (no additional model needed)
# Options: true, false
AGE_GENDER_ENABLED=true

# Enable/disable PPE (Protective Equipment) detection
# Detects helmet and glove status
# Options: true, false
PPE_DETECTION_ENABLED=true

# Confidence threshold for PPE detection (0.0-1.0)
# Higher = more confident detections, lower = more sensitive
PPE_CONFIDENCE_THRESHOLD=0.5

# Path to PPE detection model
# Default: yolov8m-protective-equipment-detection.pt
PPE_MODEL_PATH=yolov8m-protective-equipment-detection.pt

# Enable/disable people counting (zone-based)
# Counts people based on which zone they appear in and disappear from
# IN: appears in OUT zone, disappears in IN zone
# OUT: appears in IN zone, disappears in OUT zone
# Options: true, false
COUNTING_ENABLED=false

# Line dividing the frame into IN and OUT zones (ratio coords 0.0-1.0)
# Format: x,y for each point
COUNTING_LINE_START=0.0,0.5
COUNTING_LINE_END=1.0,0.5

# A point (ratio coords 0.0-1.0) that belongs to the IN zone
# Used to determine which side of the counting line is IN vs OUT
COUNTING_IN_DIRECTION_POINT=0.5,0.25

# Frames without seeing a track before considering it lost
COUNTING_CLEANUP_MAX_AGE=150

# ZMQ port for publishing crossing events to Logic Service
# Logic Service subscribes on this same port
ZMQ_PUBLISH_PORT=5555

# Enable/disable stranger alert (requires COUNTING_ENABLED=true)
# Sends alert when an Unknown person is detected in the IN zone
# Options: true, false
STRANGER_ALERT_ENABLED=false

# Interval (seconds) between repeated stranger alerts while stranger stays in IN zone
STRANGER_ALERT_INTERVAL=10

# Grace period (seconds) before confirming a stranger alert.
# Counted from when the person first appears in the frame (track created).
# Gives face recognition time to identify the person before firing an alert.
# Set to 0 to alert immediately (legacy behavior).
STRANGER_ALERT_GRACE_PERIOD=10

# Enable/disable animal detection
# Detects 10 COCO animal classes: bird, cat, dog, horse, sheep, cow, elephant, bear, zebra, giraffe
# Options: true, false
ANIMAL_DETECTION_ENABLED=false

# Interval (seconds) between repeated animal alerts while animal stays in frame
ANIMAL_ALERT_INTERVAL=10

# Confidence threshold for animal detection (0.0-1.0)
ANIMAL_CONFIDENCE_THRESHOLD=0.4

# Face database source
# "folder" = load from known_faces/ directory (default)
# "sqlite" = load pre-computed embeddings from SQLite database
FACE_DB_SOURCE=folder

# Path to SQLite database (used when FACE_DB_SOURCE=sqlite)
FACE_DB_PATH=logic_service/logic_service.db

# Video source type
# "opencv" = use cv2.VideoCapture (camera index, file, or URL via --source)
# "zmq" = receive JPEG frames from start-stream.py via ZMQ IPC
VIDEO_SOURCE_TYPE=opencv

# ZMQ endpoint for receiving frames (used when VIDEO_SOURCE_TYPE=zmq)
# Must match ZMQ_ENDPOINT in start-stream.py
ZMQ_VIDEO_ENDPOINT=ipc:///tmp/ai_frames.sock

# Timeout (ms) waiting for a frame before logging warning and retrying
# After 10 consecutive timeouts, the socket is automatically reconnected
ZMQ_RECV_TIMEOUT_MS=2000

# Directory for saving detection crop images (crossing, stranger alert, passerby)
# Images saved as: {dir}/{event_type}/{YYYY-MM-DD}/{HHMMSS}_{track_id}_{person_id}.jpg
DETECTION_IMAGE_DIR=/detection/
